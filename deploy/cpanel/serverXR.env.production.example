# Production Node.js runtime
NODE_ENV=production

# Production port for the Node backend
PORT=4000

# Public base path owned by the cPanel Node.js App
APP_BASE_PATH=/serverXR

# Persisted server data
# For staging, point this at /home/your-user/serverXR-staging/data
DATA_ROOT=/home/your-user/serverXR/data

# Keep production writes authenticated
API_TOKEN=change-me
REQUIRE_AUTH=true

# Allow your frontend origin(s)
CORS_ORIGINS=https://your-domain,https://www.your-domain

# Upload size cap in MB
MAX_UPLOAD_MB=100
