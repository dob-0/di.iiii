# Production port for the Node backend
PORT=4000

# Public base path behind Apache/cPanel
APP_BASE_PATH=/serverXR

# Persisted server data
DATA_ROOT=./data

# Keep production writes authenticated
API_TOKEN=change-me
REQUIRE_AUTH=true

# Allow your frontend origin(s)
CORS_ORIGINS=https://your-domain,https://www.your-domain

# Upload size cap in MB
MAX_UPLOAD_MB=100
