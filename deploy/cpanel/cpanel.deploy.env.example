# Copy this file on the cPanel server only.
# Suggested location:
#   ~/.config/dii/staging.deploy.env
#   ~/.config/dii/production.deploy.env
#
# Do not commit the real file with secrets.

# Frontend build-time variables
VITE_API_BASE_URL=/serverXR
VITE_API_TOKEN=replace-with-your-token

# Backend runtime variables written into serverXR/.env
NODE_ENV=production
PORT=4001
APP_BASE_PATH=/serverXR
DATA_ROOT=/home/distudio/serverXR-staging/data
SHARED_ROOT=/home/distudio/shared-staging
API_TOKEN=replace-with-your-token
REQUIRE_AUTH=true
CORS_ORIGINS=https://staging.di-studio.xyz
MAX_UPLOAD_MB=100

# Optional overrides
# CPANEL_WEB_ROOT=/home/distudio/staging.di-studio.xyz
# CPANEL_SERVERXR_ROOT=/home/distudio/serverXR-staging
# CPANEL_SHARED_ROOT=/home/distudio/shared-staging
# CPANEL_SMOKE_BASE_URL=https://staging.di-studio.xyz
# CPANEL_RUN_TESTS=1
# CPANEL_CHECKPOINT_DIR=/home/distudio/deploy-checkpoints/staging
# CPANEL_BACKUP_DIR=/home/distudio/deploy-backups
# CPANEL_SKIP_BACKUP=0
# CPANEL_SKIP_RESTART=0
# CPANEL_SKIP_SMOKE=0
