# ============================================================
# Frontend environment variables (.env.example)
# ============================================================
# Copy this file to .env (never commit .env with real values).
# See also serverXR/.env.example for backend configuration.
# ============================================================

# Base URL for the ServerXR API.
# Local dev:  use a relative path so Vite's proxy forwards requests.
#   VITE_API_BASE_URL=/serverXR
# Production: use the full URL of your deployed backend.
VITE_API_BASE_URL=https://your-api.example.com/serverXR

# Bearer token used by the frontend to authenticate write requests.
# Must match the API_TOKEN set in serverXR/.env.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
VITE_API_TOKEN=change-me
